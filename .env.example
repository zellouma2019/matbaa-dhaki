# ===== مطبعة الذكي — متغيرات البيئة =====

# قاعدة بيانات SQLite المحلية (للتطوير المحلي فقط)
DATABASE_URL=file:./db/custom.db

# مفتاح حماية لوحة التحكم المركزية (السوبر أدمن)
# غيّره لقوة قوية قبل النشر على Vercel
SUPER_ADMIN_KEY=matbaa-dhaki-2024-secret

# ===== Turso Cloud Database (مطلوب على Vercel) =====
# احصل عليها من: https://turso.tech/app/databases
TURSO_DATABASE_URL=libsql://your-db-your-org.aws-region.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# ===== ملاحظات =====
# - محلياً: يستخدم SQLite (DATABASE_URL) لتشغيل prisma db push
# - على Vercel: يستخدم Turso تلقائياً (TURSO_DATABASE_URL + TURSO_AUTH_TOKEN)
# - لإدارة الـ Schema: شغّل prisma db push محلياً، ثم انقل التغييرات لـ Turso